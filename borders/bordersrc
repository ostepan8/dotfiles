#!/usr/bin/env bash
# JankyBorders config — draws a colored outline around the focused window.
# Sourced by the `borders` service on start.
# Palette matches the Ghostty Gruvbox Dark Hard theme.

options=(
    style=round
    width=6.0
    hidpi=off

    # Gruvbox Dark Hard palette
    active_color=0xffd65d0e     # orange — focused window
    inactive_color=0xff3c3836   # dark gray — inactive windows
    background_color=0x00000000 # transparent

    # Skip borders on these apps (dialogs, native panels)
    blacklist="System Settings,Finder,Raycast"
)

borders "${options[@]}"
