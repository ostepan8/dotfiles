#!/usr/bin/env bash
# Sketchybar config — Gruvbox Dark Hard, minimal polish.
# Docs: https://felixkratz.github.io/SketchyBar/

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# ---------- Gruvbox Dark Hard palette ----------
BG_TRANSPARENT=0x00000000
BG_BAR=0xf01d2021           # 94% opacity bar background
BG_ITEM=0xff3c3836
BG_ACCENT=0xffd65d0e        # orange — active workspace
FG=0xffebdbb2
DIM=0xff928374
RED=0xffcc241d
GREEN=0xff98971a
YELLOW=0xffd79921
BLUE=0xff458588
PURPLE=0xffb16286
AQUA=0xff689d6a
BLACK=0xff1d2021

# ---------- Bar ----------
sketchybar --bar \
    position=top \
    height=32 \
    blur_radius=40 \
    color=$BG_BAR \
    padding_left=12 \
    padding_right=12 \
    y_offset=0 \
    corner_radius=0 \
    margin=0 \
    sticky=on

# ---------- Defaults applied to every item added below ----------
sketchybar --default \
    icon.font="SF Pro:Semibold:15.0" \
    icon.color=$FG \
    label.font="SF Pro:Semibold:13.0" \
    label.color=$FG \
    padding_left=6 \
    padding_right=6 \
    icon.padding_left=6 \
    icon.padding_right=6 \
    label.padding_left=0 \
    label.padding_right=6 \
    background.color=$BG_TRANSPARENT \
    background.corner_radius=8 \
    background.height=24

# ==============================================================
# LEFT SIDE
# ==============================================================

# ---------- Workspace indicators ----------
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
            background.color=$BG_TRANSPARENT \
            background.corner_radius=12 \
            background.height=24 \
            background.drawing=on \
            icon.drawing=off \
            label="$sid" \
            label.font="SF Pro:Bold:13.0" \
            label.padding_left=10 \
            label.padding_right=10 \
            padding_left=1 \
            padding_right=1 \
            click_script="aerospace workspace $sid" \
            script="$PLUGIN_DIR/aerospace.sh $sid"
done

# ---------- Gap before front app ----------
sketchybar --add item spacer.left left \
    --set spacer.left \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off \
        width=12

# ---------- Front app ----------
sketchybar --add item front_app left \
    --set front_app \
        background.drawing=off \
        icon.drawing=off \
        label.font="SF Pro:Bold:13.0" \
        label.color=$FG \
        script="$PLUGIN_DIR/front_app.sh" \
    --subscribe front_app front_app_switched

# ---------- Media / now-playing (hidden when nothing plays) ----------
sketchybar --add item media left \
    --set media \
        update_freq=10 \
        background.color=$BG_ITEM \
        label.color=$AQUA \
        drawing=off \
        script="$PLUGIN_DIR/media.sh"

# ==============================================================
# RIGHT SIDE
# Added in reverse order: first added appears rightmost.
# ==============================================================

# ---------- Clock (rightmost) ----------
sketchybar --add item clock right \
    --set clock \
        update_freq=10 \
        background.color=$BG_ITEM \
        icon="􀐫" \
        icon.color=$PURPLE \
        script="$PLUGIN_DIR/clock.sh"

# ---------- Item separator ----------
sketchybar --add item sep.1 right \
    --set sep.1 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off \
        width=6

# ---------- Battery ----------
sketchybar --add item battery right \
    --set battery \
        update_freq=120 \
        background.color=$BG_ITEM \
        script="$PLUGIN_DIR/battery.sh" \
    --subscribe battery system_woke power_source_change

# ---------- Item separator ----------
sketchybar --add item sep.2 right \
    --set sep.2 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off \
        width=6

# ---------- Volume ----------
sketchybar --add item volume right \
    --set volume \
        background.color=$BG_ITEM \
        script="$PLUGIN_DIR/volume.sh" \
        click_script="open -a 'System Settings' --args 'Sound'" \
    --subscribe volume volume_change

# ---------- Item separator ----------
sketchybar --add item sep.3 right \
    --set sep.3 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off \
        width=6

# ---------- Wi-Fi ----------
sketchybar --add item wifi right \
    --set wifi \
        update_freq=30 \
        background.color=$BG_ITEM \
        script="$PLUGIN_DIR/wifi.sh" \
    --subscribe wifi wifi_change

# ---------- Item separator ----------
sketchybar --add item sep.4 right \
    --set sep.4 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off \
        width=6

# ---------- System stats group (cpu + ram) ----------
sketchybar --add item cpu right \
    --set cpu \
        update_freq=5 \
        background.color=$BG_ITEM \
        script="$PLUGIN_DIR/cpu.sh"

sketchybar --add item ram right \
    --set ram \
        update_freq=10 \
        background.color=$BG_ITEM \
        script="$PLUGIN_DIR/ram.sh"

# ---------- Finalize ----------
sketchybar --update
