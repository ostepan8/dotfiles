# ---------- PATH + env ----------
export EDITOR=nvim
export PATH="$HOME/.local/bin:$PATH"

# ---------- mac-only paths ----------
if [[ "$(uname)" == "Darwin" ]]; then
    [ -d "$HOME/Desktop/vcpkg" ] && export PATH="$PATH:$HOME/Desktop/vcpkg"
    # NODE_OPTIONS=--use-openssl-ca intentionally omitted — conflicts with
    # NODE_USE_SYSTEM_CA (see commit 607e294).
    export AWS_CA_BUNDLE=/etc/ssl/cert.pem
    [ -f "/opt/homebrew/etc/ca-certificates/cert.pem" ] && export SSL_CERT_FILE="/opt/homebrew/etc/ca-certificates/cert.pem"
    [ -d "$HOME/Qt/5.15.2/clang_64/bin" ] && export PATH="$PATH:$HOME/Qt/5.15.2/clang_64/bin"
    [ -d "/Applications/MATLAB_R2024b.app" ] && export PATH="/Applications/MATLAB_R2024b.app/bin:$PATH"
    [ -d "/Applications/MATLAB_R2023a.app" ] && export PATH="/Applications/MATLAB_R2023a.app/bin:$PATH"
fi

# ---------- history ----------
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt EXTENDED_HISTORY
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY

# ---------- quality-of-life setopts ----------
setopt AUTO_CD               # `dirname` ≡ `cd dirname`
setopt AUTO_PUSHD            # `cd` pushes the old dir onto the stack
setopt PUSHD_IGNORE_DUPS     # don't stack the same dir twice
setopt PUSHD_SILENT          # don't print the dir stack on every cd
setopt EXTENDED_GLOB         # ^, ~, # globbing operators
setopt INTERACTIVE_COMMENTS  # allow `cmd # comment` on the command line
setopt COMPLETE_IN_WORD      # completion can split a word at the cursor
setopt NO_BEEP               # no bell

# ---------- conda (lazy) ----------
if [ -d "/opt/anaconda3" ]; then
    load_conda() {
        unset -f conda mamba load_conda 2>/dev/null
        __conda_setup="$('/opt/anaconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
        if [ $? -eq 0 ]; then
            eval "$__conda_setup"
        else
            if [ -f "/opt/anaconda3/etc/profile.d/conda.sh" ]; then
                . "/opt/anaconda3/etc/profile.d/conda.sh"
            else
                export PATH="/opt/anaconda3/bin:$PATH"
            fi
        fi
        unset __conda_setup
    }
    conda() { load_conda; conda "$@"; }
    mamba() { load_conda; mamba "$@"; }
fi

# ---------- nvm (lazy) ----------
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    load_nvm() {
        unset -f nvm node npm npx yarn pnpm corepack load_nvm 2>/dev/null
        \. "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    }
    nvm()      { load_nvm; nvm "$@"; }
    node()     { load_nvm; node "$@"; }
    npm()      { load_nvm; npm "$@"; }
    npx()      { load_nvm; npx "$@"; }
    yarn()     { load_nvm; yarn "$@"; }
    pnpm()     { load_nvm; pnpm "$@"; }
    corepack() { load_nvm; corepack "$@"; }
fi

# ---------- bun ----------
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# ---------- opencode ----------
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"

# ---------- prompt ----------
command -v starship >/dev/null && eval "$(starship init zsh)"

# ---------- aliases ----------
if [[ "$(uname)" == "Darwin" ]]; then
    alias code="zed"
    alias cursor='open -a Cursor'
fi
alias claude-tg="claude --channels plugin:telegram@claude-plugins-official"
alias ccrd="claude --resume --dangerously-skip-permissions"
# Default CLAUDE_CONFIG_DIR so bare `claude` runs against the personal
# config. The aliases and ccd/ccds/ccdw functions below override per-call.
# Also normalize a literal tilde in case something downstream set it as
# "~/..." without shell expansion (which would otherwise resolve relative
# to CWD and scatter state directories around).
export CLAUDE_CONFIG_DIR="$HOME/.claude-personal"
[[ "${CLAUDE_CONFIG_DIR-}" == "~/"* ]] && export CLAUDE_CONFIG_DIR="$HOME/${CLAUDE_CONFIG_DIR#~/}"

alias claude-personal='CLAUDE_CONFIG_DIR="$HOME/.claude-personal" claude'
alias claude-school='CLAUDE_CONFIG_DIR="$HOME/.claude-school" claude'
function _ccd_title() {
  local label="$1"; shift
  (while true; do printf '\033]0;%s\007' "$label" > /dev/tty 2>/dev/null; sleep 1; done) &
  local _pid=$!
  "$@"
  kill $_pid 2>/dev/null
  printf '\033]0;\007' > /dev/tty
}
function ccd()  { _ccd_title "Claude · ohstep23@gmail.com"       env CLAUDE_CONFIG_DIR="$HOME/.claude-personal" claude --dangerously-skip-permissions "$@"; }
function ccds() { _ccd_title "Claude · stepan.o@northeastern.edu" env CLAUDE_CONFIG_DIR="$HOME/.claude-school"   claude --dangerously-skip-permissions "$@"; }
function ccdw() { _ccd_title "Claude · owen@subconscious.dev"     env CLAUDE_CONFIG_DIR="$HOME/.claude-work"     claude --dangerously-skip-permissions "$@"; }
function ccdr()  { ccd  --resume "$@"; }
function ccdrs() { ccds --resume "$@"; }
function ccdrw() { ccdw --resume "$@"; }

alias ll='ls -lh'
alias la='ls -lAh'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias gs='git status'
alias gd='git diff'
alias gco='git checkout'
alias gl='git log --oneline --graph --decorate -20'
alias reload='source ~/.zshrc'
alias e='exit'

# ---------- completions + plugins ----------
autoload -Uz compinit && compinit
for __antidote in \
    /opt/homebrew/opt/antidote/share/antidote/antidote.zsh \
    /usr/local/opt/antidote/share/antidote/antidote.zsh \
    "$HOME/.antidote/antidote.zsh" \
    /usr/share/zsh-antidote/antidote.zsh; do
    if [ -f "$__antidote" ]; then
        source "$__antidote"
        antidote load
        break
    fi
done
unset __antidote

bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# ---------- fzf + zoxide ----------
command -v fzf >/dev/null && source <(fzf --zsh)
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

# ---------- atuin ----------
command -v atuin >/dev/null && eval "$(atuin init zsh --disable-up-arrow)"
