# Global hotkeys. Uses `alt` (Option) as the single-modifier leader.
# Conflicts to avoid: Aerospace owns alt+1-9, alt+0, alt+h/j/k/l, alt+f, alt+tab,
# alt+shift+*, alt+minus, alt+equal, alt+slash, alt+comma.

# ---------- Terminal ----------
# Opt+Space → new Ghostty window in the existing process, on the CURRENT workspace.
# Earlier this used `open -na Ghostty` which forces a NEW PROCESS each press.
# Over time that stacked up dozens of orphan ghostty processes (one Dock icon
# per process) since macOS LaunchServices registers each invocation as a
# separate app instance.
#
# We use AppleScript `click menu item "New Window"` instead of System Events
# `keystroke "n" using command down` because the keystroke variant races with
# activate: if the keystroke fires before Ghostty becomes frontmost, Cmd+N
# hits whatever app currently has focus, that app doesn't handle it, macOS
# plays the system error sound. `click menu item` queries the menu structure
# which only resolves when the app is fully active, so it serializes
# correctly and never falls through to another app.
#
# Workspace rescue: `tell ... activate` brings Ghostty's existing window to the
# front, which switches AeroSpace to that window's workspace BEFORE the new
# window is created. Without intervention, the new window inherits that
# workspace instead of the one you pressed Opt+Space from. Fix: capture the
# focused workspace first, then after the new window appears (it becomes the
# focused node), move it back to the original workspace with focus following.
alt - space : ws=$(/opt/homebrew/bin/aerospace list-workspaces --focused); osascript -e 'tell application "Ghostty" to activate' -e 'tell application "System Events" to tell process "Ghostty" to click menu item "New Window" of menu "File" of menu bar 1'; /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window "$ws"

# ---------- Chrome profiles (new window, stays on current workspace) ----------
# Opt+B → personal Chrome (Owen, ohstep23@gmail.com)
alt - b : open -a "Google Chrome" --new --args --profile-directory="Profile 1" --new-window

# Opt+W → work Chrome (owen@subconscious.dev)
alt - w : open -a "Google Chrome" --new --args --profile-directory="Profile 13" --new-window

# ---------- Other apps ----------
# Opt+E → new Finder window
alt - e : osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'

# Slack and Spotify are single-window apps; activate is the right behavior.
alt - m : open -a Spotify

# Opt+T → Bluetooth pane in System Settings (blueTooth; Opt+B is taken by Chrome)
alt - t : open "x-apple.systempreferences:com.apple.BluetoothSettings"

# ---------- Screenshots ----------
# Two flavors depending on where you're pasting:
#
# Image-bytes on clipboard — works in browsers (claude.ai), Slack, native apps
# that accept paste-image. Does NOT work in terminals (they only paste text).
#   Opt+D → selection screenshot, image bytes on clipboard
#   Opt+X → full-screen screenshot, image bytes on clipboard
# Lives on D, not C, so Claude Code's Opt+C file picker works in the terminal.
alt - d : screencapture -ic
alt - x : screencapture -c

# File-path on clipboard — works in terminals / Claude Code. Saves the
# screenshot to ~/Screenshots/<timestamp>.png and copies the absolute path
# to the clipboard. Cmd+V in the terminal pastes the path, and Claude Code
# treats a pasted absolute PNG path as an image attachment.
#   Opt+S       → full-screen → file + path on clipboard
#   Opt+Shift+S → selection   → file + path on clipboard
# Esc during the region selector cancels cleanly — no file, no clipboard write.
alt - s : mkdir -p "$HOME/Screenshots"; f="$HOME/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png"; screencapture "$f" && printf '%s' "$f" | pbcopy
alt + shift - s : mkdir -p "$HOME/Screenshots"; f="$HOME/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png"; screencapture -i "$f" && printf '%s' "$f" | pbcopy
