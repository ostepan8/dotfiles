# Global hotkeys. Uses `alt` (Option) as the single-modifier leader.
# Conflicts to avoid: Aerospace owns alt+1-9, alt+0, alt+h/j/k/l, alt+f, alt+tab,
# alt+shift+*, alt+minus, alt+equal, alt+slash, alt+comma.

# ---------- Terminal ----------
# Opt+Space → open a new Ghostty window on the CURRENT Aerospace workspace.
# `-n` forces a new instance so macOS doesn't "activate" existing Ghostty windows
# on another workspace and yank focus there. New window lands where you are.
alt - space : open -na Ghostty

# ---------- App launchers ----------
alt - b : open -a "Google Chrome"
alt - s : open -a Slack
alt - m : open -a Spotify
alt - e : open -a Finder
